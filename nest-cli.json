{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/ping-me/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/ping-me/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/ping-me",
  "projects": {
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "client-service": {
      "type": "application",
      "root": "apps/client-service",
      "entryFile": "main",
      "sourceRoot": "apps/client-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/client-service/tsconfig.app.json"
      }
    },
    "ping-me": {
      "type": "application",
      "root": "apps/ping-me",
      "entryFile": "main",
      "sourceRoot": "apps/ping-me/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ping-me/tsconfig.app.json"
      }
    }
  }
}